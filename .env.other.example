# Second Reg.ru account (zone with its own regru.env_file in config.json).
# cp .env.other.example .env.other && chmod 600 .env.other
REGU_USER=
REGU_PASS=
# SSL client cert from Reg.ru API settings (optional; defaults to ~/Desktop/regru.crt):
# REGU_SSL_CERT=~/Desktop/regru-other.crt
# REGU_SSL_KEY=~/Desktop/regru-other.key
